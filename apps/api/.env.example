NODE_ENV=development
PORT=4000

# --- Database ---
# SQLite (dev):
DATABASE_URL="file:./dev.db"
# Postgres (prod): also change `provider` in prisma/schema.prisma from "sqlite" to "postgresql"
# DATABASE_URL="postgresql://user:pass@host:5432/localio?schema=public"

# --- Auth ---
JWT_SECRET=change-me-in-prod-super-secret-key
JWT_EXPIRES_IN=30d

# --- OTP ---
# Leave OTP_DEV_BYPASS set in dev to skip SMS; unset in prod.
OTP_DEV_BYPASS=123456
# Twilio SMS (prod). All three must be set for SMS to fire.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+1...

# --- Admin gate (comma-separated phone numbers in E.164) ---
ADMIN_PHONES=+919829001000,+919829001001

# --- Storage (uploads) ---
# Dev default: local disk at ./uploads served via /uploads
# Prod: MUST switch to S3/R2/MinIO — local disk is ephemeral on every deploy.
#
# STORAGE_DRIVER=s3 is optional — presence of S3_BUCKET also triggers S3.
#
# AWS S3 example (Mumbai):
#   S3_BUCKET=localio-uploads
#   S3_REGION=ap-south-1
#   S3_ACCESS_KEY=AKIA...
#   S3_SECRET_KEY=...
#
# Cloudflare R2 example (cheaper at scale, zero egress):
#   S3_BUCKET=localio
#   S3_REGION=auto
#   S3_ACCESS_KEY=...
#   S3_SECRET_KEY=...
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_PUBLIC_BASE=https://cdn.yourapp.com    # R2 custom domain
#
# MinIO / self-hosted S3:
#   S3_ENDPOINT=https://minio.yourapp.com
#   S3_PUBLIC_BASE=https://cdn.yourapp.com
#
# STORAGE_DRIVER=s3
# S3_BUCKET=
# S3_REGION=ap-south-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=
# S3_PUBLIC_BASE=
