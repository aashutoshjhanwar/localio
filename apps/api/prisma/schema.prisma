// LOCALIO data model
// Provider: sqlite for dev, switch to postgresql for prod.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- USERS ----------

model User {
  id           String   @id @default(cuid())
  phone        String   @unique
  name         String?
  bio          String?
  avatarUrl    String?
  kycVerified  Boolean  @default(false)
  phoneVerified Boolean @default(false)
  trustScore   Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastSeenAt   DateTime?
  notificationPrefs String? // JSON map: { chat: true, offer: true, ... }

  // Location (home base)
  lat          Float?
  lng          Float?
  geohash      String?
  societyId    String?
  society      Society? @relation(fields: [societyId], references: [id])

  listings     Listing[]
  services     Service[]
  memberships  GroupMember[]
  messages     Message[]
  conversations ConversationMember[]
  ratingsGiven    Rating[] @relation("ratingsGiven")
  ratingsReceived Rating[] @relation("ratingsReceived")
  otps         Otp[]
  bookingsAsCustomer Booking[] @relation("bookingCustomer")
  bookingsAsProvider Booking[] @relation("bookingProvider")
  favorites    Favorite[]
  serviceFavorites ServiceFavorite[]
  stories      Story[]
  quickReplies QuickReply[]
  reportsMade  Report[] @relation("reportsMade")
  deviceTokens DeviceToken[]
  notifications Notification[]
  blocksMade   Block[] @relation("blocksMade")
  blockedBy    Block[] @relation("blockedBy")
  eventsCreated Event[] @relation("eventCreator")
  rsvps        EventRsvp[]
  savedSearches SavedSearch[]
  posts        Post[]
  postComments PostComment[]
  postVotes    PostVote[]
  commentVotes PostCommentVote[]
  polls        Poll[]
  pollVotes    PollVote[]

  referralCode  String? @unique
  referredById  String?
  referredBy    User?   @relation("userReferrals", fields: [referredById], references: [id])
  referrals     User[]  @relation("userReferrals")

  followsMade   Follow[] @relation("followsMade")
  followedBy    Follow[] @relation("followedBy")

  offersMade    Offer[] @relation("offerBuyer")

  wanted        Wanted[]

  kycSubmissions KycSubmission[]

  messageReactions MessageReaction[]

  @@index([geohash])
  @@index([societyId])
}

model Follow {
  id         String   @id @default(cuid())
  followerId String
  follower   User     @relation("followsMade", fields: [followerId], references: [id], onDelete: Cascade)
  followeeId String
  followee   User     @relation("followedBy", fields: [followeeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([followerId, followeeId])
  @@index([followeeId])
}

model Otp {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  phone     String
  code      String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

// ---------- GEO / SOCIETIES ----------

model Society {
  id          String   @id @default(cuid())
  name        String
  city        String
  pincode     String
  address     String?
  lat         Float
  lng         Float
  geohash     String
  memberCount Int      @default(0)
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  users    User[]
  groups   Group[]
  listings Listing[]
  services Service[]

  @@index([geohash])
  @@index([pincode])
}

// ---------- GROUPS (community chat) ----------

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  societyId   String?
  society     Society? @relation(fields: [societyId], references: [id])
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  members  GroupMember[]
  conversation Conversation? // 1:1 optional link to a conversation for group chat
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  group    Group    @relation(fields: [groupId], references: [id])
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  role     String   @default("member") // member | admin | owner
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
}

// ---------- LISTINGS (marketplace) ----------

model Listing {
  id          String   @id @default(cuid())
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  title       String
  description String
  category    String
  priceInPaise Int
  negotiable  Boolean  @default(true)
  status      String   @default("active") // active | sold | closed

  // Location
  lat         Float
  lng         Float
  geohash     String
  societyId   String?
  society     Society? @relation(fields: [societyId], references: [id])

  images      String // JSON array of URLs (sqlite-compat)
  attributes  String? // JSON blob of category-specific fields
  views       Int     @default(0)
  featured    Boolean @default(false)
  featuredUntil DateTime?
  soldToId    String?
  soldAt      DateTime?
  bumpedAt    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([geohash])
  @@index([category])
  @@index([status])

  offers      Offer[]
}

model ListingPriceChange {
  id            String   @id @default(cuid())
  listingId     String
  oldPriceInPaise Int
  newPriceInPaise Int
  changedAt     DateTime @default(now())

  @@index([listingId])
}

model Offer {
  id            String   @id @default(cuid())
  listingId     String
  listing       Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId       String
  buyer         User     @relation("offerBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  amountInPaise Int
  message       String?
  status        String   @default("pending") // pending | accepted | declined | withdrawn | countered
  counterAmountPaise Int?
  counterMessage     String?
  counteredAt        DateTime?
  createdAt     DateTime @default(now())
  respondedAt   DateTime?

  @@index([listingId])
  @@index([buyerId])
  @@index([status])
}

model KycSubmission {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  docType     String   // aadhaar | pan | dl | passport
  docUrl      String
  selfieUrl   String
  status      String   @default("pending") // pending | approved | rejected
  reason      String?
  createdAt   DateTime @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?

  @@index([userId])
  @@index([status])
}

model Wanted {
  id             String   @id @default(cuid())
  buyerId        String
  buyer          User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  title          String
  description    String
  category       String
  maxBudgetPaise Int?
  status         String   @default("open") // open | closed
  lat            Float
  lng            Float
  geohash        String
  createdAt      DateTime @default(now())

  @@index([geohash])
  @@index([category])
  @@index([status])
}

// ---------- SERVICES (Urban Company / Justdial layer) ----------

model Service {
  id          String   @id @default(cuid())
  providerId  String
  provider    User     @relation(fields: [providerId], references: [id])
  title       String
  description String
  category    String // plumber, electrician, doctor, tutor, maid...
  priceFrom   Int?   // paise, optional
  priceUnit   String? // "per_visit", "per_hour", "per_month"

  lat         Float
  lng         Float
  geohash     String
  societyId   String?
  society     Society? @relation(fields: [societyId], references: [id])

  available   Boolean @default(true)
  responseTimeMin Int? // avg minutes
  ratingAvg   Float   @default(0)
  ratingCount Int     @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  slots       ServiceSlot[]

  @@index([geohash])
  @@index([category])
}

model ServiceSlot {
  id        String   @id @default(cuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  status    String   @default("open") // open | booked | cancelled
  bookingId String?  @unique
  booking   Booking? @relation(fields: [bookingId], references: [id])
  createdAt DateTime @default(now())

  @@index([serviceId, startsAt])
  @@index([status])
}

// ---------- CHAT ----------

model Conversation {
  id        String   @id @default(cuid())
  type      String   @default("direct") // direct | group | listing
  groupId   String?  @unique
  group     Group?   @relation(fields: [groupId], references: [id])
  listingId String?  // if chat is tied to a listing
  pinnedMessageId String?
  pinnedAt        DateTime?
  pinnedById      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  ConversationMember[]
  messages Message[]
}

model ConversationMember {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime?
  archivedAt     DateTime?
  mutedUntil     DateTime?

  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User     @relation(fields: [senderId], references: [id])
  type           String   @default("text") // text | image | offer | system
  body           String
  mediaUrl       String?
  metadata       String?  // JSON blob (offer amount, etc.)
  createdAt      DateTime @default(now())
  reactions      MessageReaction[]
  replyToId      String?
  replyTo        Message? @relation("messageReplies", fields: [replyToId], references: [id])
  replies        Message[] @relation("messageReplies")
  editedAt       DateTime?
  deletedAt      DateTime?

  @@index([conversationId, createdAt])
}

model MeetupSpot {
  id        String   @id @default(cuid())
  name      String
  address   String
  lat       Float
  lng       Float
  geohash   String
  kind      String   @default("public") // mall | police | metro | park | cafe | public
  addedById String?
  createdAt DateTime @default(now())

  @@index([geohash])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// ---------- RATINGS ----------

model Rating {
  id        String   @id @default(cuid())
  fromId    String
  from      User     @relation("ratingsGiven", fields: [fromId], references: [id])
  toId      String
  to        User     @relation("ratingsReceived", fields: [toId], references: [id])
  context   String // "listing" | "service"
  contextId String // listing or service id
  stars     Int
  review    String?
  photoUrls String?  // JSON array of image URLs
  createdAt DateTime @default(now())

  @@unique([fromId, context, contextId])
  @@index([toId])
}

// ---------- BOOKINGS ----------

model Booking {
  id         String   @id @default(cuid())
  serviceId  String
  customerId String
  customer   User     @relation("bookingCustomer", fields: [customerId], references: [id])
  providerId String
  provider   User     @relation("bookingProvider", fields: [providerId], references: [id])
  status     String   @default("requested") // requested | accepted | rejected | completed | cancelled
  scheduledAt DateTime?
  notes      String?
  priceInPaise Int?
  slot       ServiceSlot?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
  @@index([providerId])
  @@index([serviceId])
}

// ---------- FAVORITES ----------

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([listingId])
}

model Story {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  mediaUrl  String?
  lat       Float
  lng       Float
  geohash   String
  societyId String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  views     StoryView[]

  @@index([userId])
  @@index([geohash, expiresAt])
  @@index([societyId, expiresAt])
}

model StoryView {
  id       String   @id @default(cuid())
  storyId  String
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId   String
  viewedAt DateTime @default(now())

  @@unique([storyId, userId])
}

model QuickReply {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model ServiceFavorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  serviceId String
  createdAt DateTime @default(now())

  @@unique([userId, serviceId])
  @@index([serviceId])
}

model HiddenListing {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

// ---------- REPORTS (moderation) ----------

model Report {
  id         String   @id @default(cuid())
  reporterId String
  reporter   User     @relation("reportsMade", fields: [reporterId], references: [id])
  targetType String   // listing | service | user | message
  targetId   String
  reason     String   // spam | scam | offensive | unsafe | other
  notes      String?
  status     String   @default("open") // open | resolved | dismissed
  createdAt  DateTime @default(now())
  resolvedAt DateTime?

  @@index([targetType, targetId])
  @@index([status])
}

// ---------- BLOCKS (mute/hide another user) ----------

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("blocksMade", fields: [blockerId], references: [id])
  blockedId String
  blocked   User     @relation("blockedBy", fields: [blockedId], references: [id])
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// ---------- NOTIFICATIONS (in-app inbox) ----------

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // booking_request | booking_update | chat | system
  title     String
  body      String
  data      String?  // JSON payload for client routing
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ---------- COMMUNITY POSTS (ask / recommend / lost-found / announce) ----------

model Post {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  kind      String   // question | recommendation | lost_found | announcement
  title     String
  body      String
  images    String?  // JSON-encoded array of image URLs
  lat       Float
  lng       Float
  geohash   String
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())

  comments PostComment[]
  votes    PostVote[]

  @@index([geohash])
  @@index([kind])
  @@index([createdAt])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  likes     Int      @default(0)
  createdAt DateTime @default(now())

  commentVotes PostCommentVote[]

  @@index([postId, createdAt])
}

model PostCommentVote {
  id        String      @id @default(cuid())
  commentId String
  comment   PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  createdAt DateTime    @default(now())

  @@unique([commentId, userId])
}

model PostVote {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

// ---------- POLLS ----------

model Poll {
  id         String   @id @default(cuid())
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  question   String
  lat        Float
  lng        Float
  geohash    String
  closesAt   DateTime?
  createdAt  DateTime @default(now())

  options PollOption[]
  votes   PollVote[]

  @@index([geohash])
  @@index([createdAt])
}

model PollOption {
  id       String   @id @default(cuid())
  pollId   String
  poll     Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label    String
  idx      Int
  votes    PollVote[]

  @@index([pollId])
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([pollId, userId])
  @@index([optionId])
}

// ---------- SAVED SEARCHES (alerts on new matches) ----------

model SavedSearch {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  label         String
  q             String?
  category      String?
  kind          String   @default("both") // listing | service | both
  lat           Float
  lng           Float
  geohash       String
  radiusKm      Float    @default(10)
  createdAt     DateTime @default(now())
  lastNotifiedAt DateTime?

  @@index([userId])
  @@index([geohash])
}

// ---------- EVENTS (community meet-ups) ----------

model Event {
  id          String   @id @default(cuid())
  creatorId   String
  creator     User     @relation("eventCreator", fields: [creatorId], references: [id])
  title       String
  description String
  locationText String
  lat         Float
  lng         Float
  geohash     String
  startsAt    DateTime
  endsAt      DateTime?
  capacity    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rsvps EventRsvp[]

  @@index([geohash])
  @@index([startsAt])
}

model EventRsvp {
  id       String   @id @default(cuid())
  eventId  String
  event    Event    @relation(fields: [eventId], references: [id])
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  status   String   @default("going") // going | interested
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([userId])
}

// ---------- DEVICE TOKENS (push) ----------

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  platform  String   // ios | android | web
  createdAt DateTime @default(now())

  @@index([userId])
}
